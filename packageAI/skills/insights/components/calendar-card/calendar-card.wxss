.calendar-card { padding: 24rpx; }
.calendar-header { font-size: 32rpx; font-weight: 500; color: #333; margin-bottom: 16rpx; }
.calendar-days { display: flex; flex-wrap: wrap; }
.day-item { width: 33%; padding: 8rpx 0; }
.date { font-size: 26rpx; color: #333; }
.count { font-size: 24rpx; color: #00b26a; margin-left: 8rpx; }
