<view class="op-card" wx:if="{{result}}">
  <view class="op-icon {{result.isError ? 'error' : 'success'}}">
    <text wx:if="{{!result.isError}}">✓</text>
    <text wx:else>✕</text>
  </view>
  <view class="op-title {{result.isError ? 'error' : 'success'}}">
    {{result.isError ? '操作失败' : '已完成'}}
  </view>
  <view class="op-desc">共享待办已完成</view>
</view>
