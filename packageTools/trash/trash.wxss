/* ===========================================
   回收站 · 时光绿径待办
   完整重设计 — 继承全局配色/圆角/风格
   功能层零改动
   =========================================== */

/* ---------- 全局重置 ---------- */
.page {
  min-height: 100vh;
  padding: 0 24rpx 120rpx;
}

/* ===========================================
   1. 顶部
   =========================================== */
.hero {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 24rpx;
  overflow: hidden;
}

.hero-bg-decor {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

.hero-blob {
  position: absolute;
  border-radius: 50%;
}

.hb-1 {
  width: 420rpx;
  height: 420rpx;
  background: radial-gradient(circle, rgba(0,178,106,0.08) 0%, transparent 70%);
  top: -140rpx;
  right: -80rpx;
  animation: blobDrift 6s ease-in-out infinite;
}

.hb-2 {
  width: 280rpx;
  height: 280rpx;
  background: radial-gradient(circle, rgba(16,185,129,0.06) 0%, transparent 70%);
  bottom: -40rpx;
  left: -60rpx;
  animation: blobDrift 8s ease-in-out infinite reverse;
}

@keyframes blobDrift {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(20rpx, -20rpx); }
}

.hero-icon-box {
  position: relative;
  z-index: 1;
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #00b26a 0%, #2ddaa0 100%);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(0,178,106,0.28);
  animation: iconPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes iconPop {
  0% { transform: scale(0); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.hero-title {
  position: relative;
  z-index: 1;
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 6rpx;
  letter-spacing: 2rpx;
}

.hero-desc {
  position: relative;
  z-index: 1;
  font-size: 24rpx;
  color: #999;
}

/* ===========================================
   2. 状态条
   =========================================== */
.status-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  background: rgba(0,178,106,0.06);
  border-radius: 20rpx;
  animation: fadeUp 0.4s ease 0.1s both;
}

.status-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-text {
  font-size: 24rpx;
  color: #555;
}

/* ===========================================
   3. 未登录引导
   =========================================== */
.login-banner {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 28rpx 24rpx 24rpx;
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  position: relative;
  overflow: hidden;
  animation: fadeUp 0.4s ease 0.1s both;
}

.login-banner::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #00b26a, #3ddaa0, #00b26a);
  background-size: 200% 100%;
  animation: shimmer 3s ease infinite;
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.login-banner-bg {
  display: none;
}

.login-body {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.login-icon-area {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.login-text-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.login-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.login-desc {
  font-size: 24rpx;
  color: #999;
}

.login-btn {
  margin: 0;
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #00b26a 0%, #06ad56 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(0,178,106,0.25);
  transition: transform 0.2s, box-shadow 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(0,178,106,0.12);
}

.login-btn::after {
  border: none;
}

/* ===========================================
   4. 列表分割标题
   =========================================== */
.list-area {
  animation: fadeUp 0.4s ease 0.1s both;
}

.list-divider {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 8rpx 0 20rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #e8e8e8;
}

.divider-label {
  font-size: 24rpx;
  color: #bbb;
  flex-shrink: 0;
  font-weight: 500;
}

/* ===========================================
   5. 卡片待办项（全新设计）
   =========================================== */
.todo-item {
  display: flex;
  margin-bottom: 20rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  transition: transform 0.2s, box-shadow 0.2s;
  animation: cardIn 0.4s ease both;
}

.todo-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

/* staggered entrance */
.todo-item:nth-child(1)  { animation-delay: 0.03s; }
.todo-item:nth-child(2)  { animation-delay: 0.06s; }
.todo-item:nth-child(3)  { animation-delay: 0.09s; }
.todo-item:nth-child(4)  { animation-delay: 0.12s; }
.todo-item:nth-child(5)  { animation-delay: 0.15s; }
.todo-item:nth-child(6)  { animation-delay: 0.18s; }
.todo-item:nth-child(7)  { animation-delay: 0.21s; }
.todo-item:nth-child(8)  { animation-delay: 0.24s; }
.todo-item:nth-child(9)  { animation-delay: 0.27s; }
.todo-item:nth-child(10) { animation-delay: 0.30s; }

@keyframes cardIn {
  0%   { opacity: 0; transform: translateY(16rpx) scale(0.98); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}

/* 卡片主体 */
.item-body {
  flex: 1;
  padding: 22rpx 20rpx 20rpx;
  min-width: 0;
}

/* 标题行 */
.item-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.item-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
  word-break: break-all;
  min-width: 0;
}

/* 天数徽章 */
.item-chip {
  flex-shrink: 0;
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.5;
}

.chip-safe   { background: #f5f5f5; color: #888; }
.chip-warn   { background: #fef3c7; color: #b45309; }
.chip-danger { background: #fee2e2; color: #dc2626; }

/* 元数据行 */
.item-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 18rpx;
}

.meta-unit {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #aaa;
}

.meta-dot {
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: #ddd;
  flex-shrink: 0;
}

/* 按钮行 */
.item-actions {
  display: flex;
  gap: 12rpx;
}

.act {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 68rpx;
  border-radius: 34rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
  transition: transform 0.15s, box-shadow 0.15s;
  margin: 0;
  padding: 0;
}

.act:active {
  transform: scale(0.96);
}

.act::after { border: none; }

.act-restore {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
  color: #059669;
  box-shadow: 0 2rpx 8rpx rgba(16,185,129,0.12);
}

.act-restore:active {
  box-shadow: 0 1rpx 4rpx rgba(16,185,129,0.06);
}

.act-delete {
  background: #fff;
  color: #ef4444;
  border: 2rpx solid #fee2e2;
}

.act-delete:active {
  background: #fef2f2;
}

/* ===========================================
   6. 列表底部提示
   =========================================== */
.list-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0;
}

.list-footer text {
  font-size: 22rpx;
  color: #bbb;
}

/* ===========================================
   7. 空状态
   =========================================== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0 60rpx;
  animation: fadeUp 0.5s ease 0.1s both;
}

.empty-icon-box {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  animation: floatY 4s ease-in-out infinite;
}

@keyframes floatY {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #bbb;
}

/* ===========================================
   8. 通用动画
   =========================================== */
@keyframes fadeUp {
  0%   { opacity: 0; transform: translateY(16rpx); }
  100% { opacity: 1; transform: translateY(0); }
}
