<view class="page">

  <!-- 主体内容 -->
  <view class="content">
    <t-tabs value="{{currentType}}" bind:change="onTypeChange">
      <t-tab-panel label="日报模板" value="daily">
        <view class="section-list">
          <view class="section-card" wx:for="{{dailySections}}" wx:key="key" data-index="{{index}}">
            <view class="card-header">
              <t-icon name="move" size="36rpx" color="#ccc" />
              <t-input
                class="section-title-input"
                value="{{item.title}}"
                placeholder="输入段落名称"
                data-type="daily"
                data-index="{{index}}"
                bind:change="onSectionTitleInput"
              />
              <view class="delete-icon" data-type="daily" data-index="{{index}}" bindtap="deleteSection">
                <t-icon name="delete" size="36rpx" color="#ff4d4f" />
              </view>
            </view>
            <view class="card-meta">
              <text class="meta-text">最多 {{item.max_lines || 20}} 行</text>
            </view>
          </view>
          <view wx:if="{{dailySections.length === 0}}" class="empty-hint">
            <text>暂无日报段落，点击下方添加</text>
          </view>
        </view>
        <view class="add-section-btn" data-type="daily" bindtap="addSection">
          <t-icon name="add" size="36rpx" color="#00b26a" />
          <text class="add-text">添加 Section</text>
        </view>
      </t-tab-panel>
      <t-tab-panel label="周报模板" value="weekly">
        <view class="section-list">
          <view class="section-card" wx:for="{{weeklySections}}" wx:key="key" data-index="{{index}}">
            <view class="card-header">
              <t-icon name="move" size="36rpx" color="#ccc" />
              <t-input
                class="section-title-input"
                value="{{item.title}}"
                placeholder="输入段落名称"
                data-type="weekly"
                data-index="{{index}}"
                bind:change="onSectionTitleInput"
              />
              <view class="delete-icon" data-type="weekly" data-index="{{index}}" bindtap="deleteSection">
                <t-icon name="delete" size="36rpx" color="#ff4d4f" />
              </view>
            </view>
            <view class="card-meta">
              <text class="meta-text">最多 {{item.max_lines || 20}} 行</text>
            </view>
          </view>
          <view wx:if="{{weeklySections.length === 0}}" class="empty-hint">
            <text>暂无周报段落，点击下方添加</text>
          </view>
        </view>
        <view class="add-section-btn" data-type="weekly" bindtap="addSection">
          <t-icon name="add" size="36rpx" color="#00b26a" />
          <text class="add-text">添加 Section</text>
        </view>
      </t-tab-panel>
    </t-tabs>

    <!-- 底部保存按钮 -->
    <view class="save-area">
      <t-button block theme="primary" bindtap="saveTemplates">保存模板</t-button>
    </view>
  </view>
</view>
