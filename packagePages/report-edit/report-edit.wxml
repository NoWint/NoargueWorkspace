<wxs module="utils">
module.exports = {
  includes: function(arr, val) {
    if (!arr) return false;
    if (typeof arr.length === 'undefined') return false;
    if (arr.length === 0) return false;
    for (var i = 0; i < arr.length; i++) {
      if (arr[i] == val) return true;
    }
    return false;
  }
}
</wxs>

<!-- 自定义导航栏 -->
<view class="nav-bar" style="padding-top: {{navBarHeight - 22}}px; padding-left: {{menuRight + 20}}rpx; padding-right: {{menuRight + 20}}rpx;">
  <view class="nav-left" bindtap="goBack">
    <t-icon name="chevron-left" size="48rpx" color="#2d3436" />
  </view>
  <text class="nav-title">{{navTitle}}</text>
  <view class="nav-right" bindtap="saveReport">
    <t-icon name="check" size="48rpx" color="#00b26a" />
  </view>
</view>

<scroll-view class="scroll-area" scroll-y style="padding-top: {{navBarHeight + 10}}px;">

  <!-- 汇报到选择器 -->
  <view class="target-selector" bindtap="showComboPicker">
    <view class="target-label">
      <t-icon name="flag" size="32rpx" color="#00b26a" />
      <text class="target-text">汇报到</text>
    </view>
    <view class="target-value">
      <text class="target-name">{{selectedComboName}}</text>
      <t-icon name="chevron-down" size="32rpx" color="#999" />
    </view>
  </view>

  <view class="target-hint">{{targetDateHint}}</view>

  <!-- 区块卡片列表 -->
  <view class="sections-container">
    <view class="section-card" wx:for="{{sections}}" wx:key="key" wx:for-index="sectionIndex" data-section-index="{{sectionIndex}}">

      <!-- 区块标题 -->
      <view class="section-header">
        <view class="section-title-row">
          <view class="section-dot" style="background: {{item.color}}"></view>
          <text class="section-title">{{item.title}}</text>
          <view class="section-badge">{{item.lines.length}}条</view>
        </view>
      </view>

      <!-- 行列表 -->
      <view class="lines-container">
        <view class="line-item" wx:for="{{item.lines}}" wx:key="index" wx:for-index="lineIndex" data-section-index="{{sectionIndex}}" data-line-index="{{lineIndex}}">
          <view class="line-dot" style="background: {{item.color}}"></view>
          <textarea
            class="line-textarea"
            value="{{item.lines[lineIndex]}}"
            auto-height
            placeholder="输入内容..."
            maxlength="500"
            data-section="{{sectionIndex}}"
            data-line="{{lineIndex}}"
            bindinput="onLineInput"
            bindfocus="onLineFocus"
          />
          <view class="line-actions">
            <view wx:if="{{isPlanSection(item.key)}}" class="line-action-btn" bindtap="addLineToTodo" data-section="{{sectionIndex}}" data-line="{{lineIndex}}">
              <t-icon name="add" size="32rpx" color="#00b26a" />
            </view>
            <view class="line-action-btn delete-btn" bindtap="deleteLine" data-section="{{sectionIndex}}" data-line="{{lineIndex}}">
              <t-icon name="close" size="32rpx" color="#ff4d4f" />
            </view>
          </view>
        </view>
      </view>

      <!-- 区块操作按钮 -->
      <view class="section-actions">
        <view wx:if="{{!isPlanSection(item.key)}}" class="section-action-btn" bindtap="importFromTodos" data-section="{{sectionIndex}}">
          <t-icon name="download" size="28rpx" color="#00b26a" />
          <text class="action-text">从待办导入</text>
        </view>
        <view class="section-action-btn primary" bindtap="addLine" data-section="{{sectionIndex}}">
          <t-icon name="add" size="28rpx" color="#00b26a" />
          <text class="action-text">添加新条目</text>
        </view>
      </view>

    </view>
  </view>

  <!-- 底部安全区域 -->
  <view class="bottom-safe"></view>

</scroll-view>

<!-- 组合选择 Popup -->
<t-popup
  visible="{{showComboPicker}}"
  bind:visible-change="onComboPickerVisibleChange"
  placement="bottom"
  close-on-overlay-click="{{true}}"
  z-index="11000"
  overlay-props="{{ { zIndex: 10999 } }}"
>
  <view class="combo-picker-content">
    <view class="popup-header">
      <text class="popup-title">选择汇报组合</text>
      <view class="popup-close" bindtap="hideComboPicker">
        <t-icon name="close" size="40rpx" color="#999" />
      </view>
    </view>

    <t-radio-group value="{{comboPickerMode}}" bind:change="onComboModeChange">
      <view class="mode-options">
        <t-radio label="私人" value="private" />
        <t-radio label="共享组合" value="shared" />
      </view>
    </t-radio-group>

    <scroll-view class="combo-list-scroll" scroll-y>
      <view wx:if="{{comboPickerMode === 'private' && privateCombos.length > 0}}" class="combo-options">
        <view
          class="combo-card {{selectedComboId === item.id && !isSharedCombo ? 'selected' : ''}}"
          wx:for="{{privateCombos}}"
          wx:key="id"
          data-id="{{item.id}}"
          data-name="{{item.name}}"
          data-shared="0"
          bindtap="selectCombo"
        >
          <view class="combo-card-icon" style="background: {{item.color || '#4CAF50'}}">
            <t-icon name="{{item.icon || 'folder'}}" size="36rpx" color="#fff" />
          </view>
          <view class="combo-card-info">
            <text class="combo-card-name">{{item.name}}</text>
            <text class="combo-card-count">{{item.todoCount || 0}}个待办</text>
          </view>
          <t-icon wx:if="{{selectedComboId === item.id && !isSharedCombo}}" name="check" size="36rpx" color="#00b26a" />
        </view>
      </view>

      <view wx:if="{{comboPickerMode === 'shared' && sharedCombos.length > 0}}" class="combo-options">
        <view
          class="combo-card {{selectedComboId === item.id && isSharedCombo ? 'selected' : ''}}"
          wx:for="{{sharedCombos}}"
          wx:key="id"
          data-id="{{item.id}}"
          data-name="{{item.name}}"
          data-shared="1"
          bindtap="selectCombo"
        >
          <view class="combo-card-icon" style="background: {{item.color || '#2196F3'}}">
            <t-icon name="{{item.icon || 'user-group'}}" size="36rpx" color="#fff" />
          </view>
          <view class="combo-card-info">
            <text class="combo-card-name">{{item.name}}</text>
            <text class="combo-card-count">{{item.todoCount || 0}}个待办 · {{item.memberCount || 1}}人</text>
          </view>
          <t-icon wx:if="{{selectedComboId === item.id && isSharedCombo}}" name="check" size="36rpx" color="#00b26a" />
        </view>
      </view>

      <view wx:if="{{comboPickerMode === 'shared' && sharedCombos.length === 0}}" class="empty-combos">
        <text>暂无可用的共享组合</text>
      </view>
      <view wx:if="{{comboPickerMode === 'private' && privateCombos.length === 0}}" class="empty-combos">
        <text>暂无私密组合</text>
      </view>
    </scroll-view>

    <view class="combo-confirm-area">
      <t-button block theme="primary" bindtap="confirmCombo">确定</t-button>
    </view>
  </view>
</t-popup>

<!-- 待办导入 Popup -->
<t-popup
  visible="{{showImportPopup}}"
  bind:visible-change="onImportPopupVisibleChange"
  placement="bottom"
  close-on-overlay-click="{{true}}"
  z-index="11000"
  overlay-props="{{ { zIndex: 10999 } }}"
>
  <view class="import-popup-content">
    <view class="popup-header">
      <text class="popup-title">从待办导入</text>
      <view class="popup-close" bindtap="hideImportPopup">
        <t-icon name="close" size="40rpx" color="#999" />
      </view>
    </view>

    <scroll-view class="import-scroll" scroll-y>
      <!-- 已完成 -->
      <view wx:if="{{importTodos.completed.length > 0}}" class="import-section">
        <text class="import-section-title">已完成（{{importTodos.completed.length}}）</text>
        <view
          class="import-todo-item {{utils.includes(selectedImportTodos, item._key) ? 'selected' : ''}}"
          wx:for="{{importTodos.completed}}"
          wx:key="_key"
          data-key="{{item._key}}"
          bindtap="toggleImportTodo"
        >
          <view class="import-todo-text">{{item.text}}</view>
          <t-icon wx:if="{{utils.includes(selectedImportTodos, item._key)}}" name="check-circle-filled" size="36rpx" color="#00b26a" />
          <t-icon wx:else name="circle" size="36rpx" color="#ccc" />
        </view>
      </view>

      <!-- 未完成 -->
      <view wx:if="{{importTodos.uncompleted.length > 0}}" class="import-section">
        <text class="import-section-title">未完成（{{importTodos.uncompleted.length}}）</text>
        <view
          class="import-todo-item {{utils.includes(selectedImportTodos, item._key) ? 'selected' : ''}}"
          wx:for="{{importTodos.uncompleted}}"
          wx:key="_key"
          data-key="{{item._key}}"
          bindtap="toggleImportTodo"
        >
          <view class="import-todo-text">{{item.text}}</view>
          <t-icon wx:if="{{utils.includes(selectedImportTodos, item._key)}}" name="check-circle-filled" size="36rpx" color="#00b26a" />
          <t-icon wx:else name="circle" size="36rpx" color="#ccc" />
        </view>
      </view>

      <view wx:if="{{importTodos.completed.length === 0 && importTodos.uncompleted.length === 0}}" class="empty-combos">
        <text>该日期没有待办</text>
      </view>
    </scroll-view>

    <view class="import-confirm-area">
      <t-button block theme="primary" bindtap="confirmImport">
        导入（{{selectedImportTodos.length}}条）
      </t-button>
    </view>
  </view>
</t-popup>
