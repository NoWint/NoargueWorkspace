/* ========================================
   个人中心 - 时光绿径待办
   设计语言：清新自然 · 卡片化 · 微交互
   ======================================== */

/* ---------- 全局 ---------- */
.container {
  min-height: 100vh;
  padding: 0 20rpx 120rpx;
  position: relative;
}

/* ========== 登录态 ========== */
.login-section {
  position: relative;
  overflow: hidden;
}

.login-decor {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
  height: 600rpx;
  pointer-events: none;
}

.decor-circle {
  position: absolute;
  border-radius: 50%;
}

.decor-c1 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(0, 178, 106, 0.12) 0%, transparent 70%);
  top: -100rpx;
  left: -50rpx;
}

.decor-c2 {
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(16, 185, 129, 0.08) 0%, transparent 70%);
  top: 80rpx;
  right: -80rpx;
}

.decor-c3 {
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(45, 212, 191, 0.08) 0%, transparent 70%);
  bottom: -40rpx;
  left: 50%;
  transform: translateX(-50%);
}

.login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 48rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx) saturate(180%);
  -webkit-backdrop-filter: blur(20rpx) saturate(180%);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  position: relative;
  z-index: 1;
  box-shadow: 0 8rpx 40rpx rgba(0, 178, 106, 0.1);
}

.login-avatar-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 1rpx;
  background: linear-gradient(135deg, #00b26a, #3ddaa0);
  margin-bottom: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-avatar {
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.login-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #999;
  line-height: 1.5;
  text-align: center;
  margin-bottom: 40rpx;
}

.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #00b26a 0%, #06ad56 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 178, 106, 0.3);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.login-btn:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(0, 178, 106, 0.2);
}

.login-btn::after {
  border: none;
}

.login-hint {
  font-size: 24rpx;
  color: #bbb;
  margin-top: 24rpx;
}

/* ========== 已登录态 ========== */
.user-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-top: 12rpx;
}

/* --- 问候语（独立于卡片，作为页头） --- */
.greeting-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 16rpx 0;
}

.greeting-text {
  font-size: 48rpx;
  font-weight: 500;
  color: #1a1a1a;
}

/* --- 个人资料卡片（极简白卡） --- */
.profile-card {
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.profile-content {
  padding: 32rpx 28rpx;
}

.profile-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-wrapper {
  position: relative;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 1;
  flex-shrink: 0;
  width: 136rpx;
  height: 136rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-wrapper::after {
  border: none;
}

.avatar-ring {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  padding: 4rpx;
  background: linear-gradient(135deg, #00b26a, #3ddaa0);
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.avatar-edit-badge {
  position: absolute;
  right: -2rpx;
  bottom: 0rpx;
  width: 44rpx;
  height: 44rpx;
  background: #00b26a;
  border: 3rpx solid #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 178, 106, 0.3);
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.user-nickname {
  font-size: 44rpx;
  font-weight: 600;
  color: #1a1a1a;
  max-width: 380rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-nickname.placeholder {
  font-weight: 400;
  opacity: 0.5;
}

.name-edit-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f0fdf6;
  transition: background 0.2s;
}

.name-edit-btn:active {
  background: #d1fae5;
}

/* 昵称编辑态 */
.nickname-edit-bar {
  margin-top: 20rpx;
  animation: editSlideDown 0.25s ease;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
}

@keyframes editSlideDown {
  from { opacity: 0; transform: translateY(-10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.nickname-edit-inner {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.nickname-input {
  width: 100%;
  height: 80rpx;
  background: #f5faf7;
  border-radius: 20rpx;
  text-align: center;
  font-size: 30rpx;
  color: #333;
}

.edit-actions {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.edit-btn {
  font-size: 28rpx;
  padding: 14rpx 48rpx;
  border-radius: 28rpx;
  font-weight: 500;
}

.edit-btn.cancel {
  color: #999;
  background: #f5f5f5;
}

.edit-btn.confirm {
  background: #00b26a;
  color: #fff;
}

/* --- 每日一言 --- */
.daily-motto {
  padding: 0 24rpx 38rpx;
  font-size: 42rpx;
  line-height: 1.5;
}

/* --- 数据概览卡片 --- */
.stats-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.stats-row {
  display: flex;
  align-items: center;
  padding: 0 16rpx;
}

.stats-row-top {
  padding-bottom: 24rpx;
}

.stats-row-sep {
  height: 1rpx;
  background: #f0f0f0;
  margin: 0 32rpx 24rpx;
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  min-width: 0;
}

.stats-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.2;
}

.stats-limit {
  font-size: 26rpx;
  font-weight: 400;
  color: #bbb;
}

.stats-label {
  font-size: 22rpx;
  color: #999;
}

.stats-divider {
  width: 1rpx;
  height: 56rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

/* --- 账号信息（可折叠） --- */
.collapse-section {
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.collapse-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}

.collapse-header:active {
  background: #fafafa;
}

.collapse-header-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.collapse-title {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.collapse-body {
  padding: 0 32rpx 24rpx;
  animation: collapseFadeIn 0.25s ease;
}

@keyframes collapseFadeIn {
  from { opacity: 0; transform: translateY(-8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
}

.info-divider {
  height: 1rpx;
  background: #f5f5f5;
  margin: 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}

.info-value-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
  max-width: 65%;
  padding: 8rpx 14rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.info-value-wrap:active {
  background: #f0f0f0;
}

.info-value {
  font-size: 24rpx;
  color: #666;
  font-family: monospace;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-value.openid {
  font-size: 20rpx;
}

/* --- 退出登录 --- */
.logout-section {
  margin-top: 8rpx;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  transition: transform 0.2s ease, background 0.2s ease;
}

.logout-hover {
  transform: scale(0.98) !important;
  background: #fef2f2 !important;
}

.logout-text {
  font-size: 28rpx;
  color: #e34d59;
  font-weight: 500;
}

/* ========== 入场动画 ========== */
.user-section {
  animation: sectionFadeIn 0.4s ease;
}

@keyframes sectionFadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.login-card {
  animation: cardFloatIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes cardFloatIn {
  from { opacity: 0; transform: translateY(30rpx) scale(0.97); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

/* 逐项入场动画 */
.stats-card {
  animation: slideUp 0.4s ease 0.05s both;
}

.collapse-section {
  animation: slideUp 0.4s ease 0.1s both;
}

.logout-section {
  animation: slideUp 0.4s ease 0.15s both;
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
